{
	"appId": "tw.legislature.app",
	"appName": "立法院",
	"webDir": "www",
	"bundledWebRuntime": false,
	"backgroundColor": "#f2f4f7",
	"server": {
		"hostname": "app.legislature.tw",
		"iosScheme": "https",
		"androidScheme": "https"
	},
	"plugins": {
		"LocalNotifications": {
			"smallIcon": "ic_stat_icon_config_sample",
			"iconColor": "#003153",
			"sound": "beep.wav"
		},
		"PushNotifications": {
			"presentationOptions": [
				"badge",
				"sound"
			]
		}
	},
	"packageClassList": [
		"FCMPlugin",
		"LocalNotificationsPlugin",
		"PushNotificationsPlugin"
	]
}
